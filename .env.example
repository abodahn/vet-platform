# ═══════════════════════════════════════════════════════════
#  Premium Animal Hospital Platform — Environment Variables
#  Copy to .env and fill in your real values
#  Never commit .env to Git
# ═══════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────
POSTGRES_DSN=postgresql://DB_USER:DB_PASSWORD@localhost:5432/vetclinic

# ── Security ─────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
PLATFORM_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_128_CHAR_HEX_STRING
SESSION_COOKIE_SECURE=true

# ── Admin Seed ────────────────────────────────────────────
PLATFORM_ADMIN_USER=admin
PLATFORM_ADMIN_PASS=CHANGE_ME_MIN_12_CHARS

# ── App ──────────────────────────────────────────────────
PLATFORM_DEBUG=0
PLATFORM_PORT=5100
PLATFORM_HOST=0.0.0.0

# ── Branding ─────────────────────────────────────────────
PLATFORM_TITLE=Premium Animal Hospital
PLATFORM_TITLE_AR=مستشفى بريميوم للحيوانات
PLATFORM_SUBTITLE=Dr. Hatem El Khateeb

# ── Legacy app ───────────────────────────────────────────
LEGACY_APP_URL=http://localhost:5000
LEGACY_APP_ENABLED=1
